# ============================================================
#  .env.example — Copia este archivo como .env y rellena los valores
#  NUNCA subas el .env real a GitHub
# ============================================================

# ── PrestaShop Webservice ────────────────────────────────────
# Generar en: PS Admin → Parámetros avanzados → Webservice → Añadir clave
PS_API_KEY=TU_API_KEY_AQUI
PS_BASE_URL=https://tu-tienda.com/api

# ── Base de datos MySQL (PrestaShop) ─────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_contraseña_mysql
DB_NAME=tu_base_de_datos

# ── Rutas locales ────────────────────────────────────────────
IMG_PATH=./static/images/

# ── Servidor ─────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=false

# ── JWT ──────────────────────────────────────────────────────
# Genera una clave segura con:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=clave_secreta_minimo_32_caracteres
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=240
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
